# Gemini Edge Function (AI key stays on Supabase secrets, never in frontend)
VITE_GEMINI_FUNCTION_NAME="gemini-proxy"

# Supabase (required for remote database sync)
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
VITE_SUPABASE_APP_STATE_ID="hiwrys-project"

# Project metadata (not used by frontend runtime)
SUPABASE_PROJECT_NAME="Hiwry's Project"
SUPABASE_DB_PASSWORD="YOUR_SUPABASE_DB_PASSWORD"
